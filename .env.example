# Copy this file to .env for local/private backend use only.
# Never commit real API keys to GitHub.

# NVIDIA NIM / NVIDIA Build API
NVIDIA_API_KEY=replace_with_your_nvidia_key
NVIDIA_BASE_URL=https://integrate.api.nvidia.com/v1
NVIDIA_MODEL=nvidia/nemotron-3-ultra-550b-a55b

# Optional future providers
GROQ_API_KEY=
OPENROUTER_API_KEY=

# Optional internal/on-prem AI server
LOCAL_AI_SERVER_URL=http://127.0.0.1:8000
LOCAL_AI_SERVER_API_KEY=
